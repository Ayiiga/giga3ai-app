{
  "expo": {
    "name": "Giga3 AI",
    "slug": "giga3-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "giga3ai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "AI-powered creator, student, and productivity platform",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.giga3ai.app"
    },
    "android": {
      "package": "com.giga3ai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "giga3-ai-production"
      }
    }
  }
}